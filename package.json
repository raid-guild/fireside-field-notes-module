{
  "name": "edge-report-module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"const fs=require('fs');const p='.next';if(!fs.existsSync(p))process.exit(0);for(const e of fs.readdirSync(p)){if(e==='cache')continue;fs.rmSync(p+'/'+e,{recursive:true,force:true});}\"",
    "dev": "next dev --port 3310",
    "dev:clean": "pnpm clean && pnpm dev",
    "build": "next build",
    "build:clean": "pnpm clean && pnpm build",
    "start": "next start -H 0.0.0.0 -p ${PORT:-3310}",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0"
  }
}